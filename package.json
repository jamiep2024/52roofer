{
  "name": "52roofer",
  "version": "1.0.0",
  "private": true,
  "author": "jamiep2024",
  "license": "MIT",
  "description": "52Roofer - Professional Roofing Services Website",
  "scripts": {
    "dev": "next dev",
    "build": "next build && next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "verify": "node scripts/verify-all-urls.js",
    "check-links": "node scripts/verify-site-health.js",
    "analyze": "cross-env ANALYZE=true next build",
    "sitemap": "node ./scripts/generate-sitemap.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "postbuild": "next-sitemap",
    "test": "echo \"No tests specified\"",
    "fix-schemas": "node scripts/fix-schemas.js",
    "prepare": "husky install",
    "check-urls": "ts-node --project tsconfig.json scripts/check-urls.ts",
    "check": "ts-node scripts/check-urls.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "fs-extra": "^11.2.0",
    "next": "15.1.3",
    "next-seo": "^6.6.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "schema-dts": "^1.1.2",
    "sitemap-generator": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.1.3",
    "@svgr/webpack": "8.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "8.1.0",
    "@types/node": "22.10.5",
    "@types/node-fetch": "2.6.12",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.3",
    "glob": "11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "node-fetch": "3.3.2",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "ts-node": "10.9.2",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.6.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
