# Gmail App Password (not your regular Gmail password)
EMAIL_PASSWORD=your_app_password_here

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="your_private_key_here"

# Form Submission Configuration
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=your_google_script_url_here

# Example:
# NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
